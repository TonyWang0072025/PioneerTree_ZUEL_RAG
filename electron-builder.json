{
  "productName": "前人树",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "node_modules/better-sqlite3/**/*",
    "node_modules/vditor/**/*",
    "node_modules/pdfjs-dist/**/*",
    "node_modules/mammoth/**/*",
    "node_modules/marked/**/*",
    "node_modules/katex/**/*"
  ],
  "extraResources": [
    {
      "from": "resources/documents",
      "to": "documents",
      "filter": ["**/*"]
    },
    {
      "from": "resources/dist-data",
      "to": "dist-data",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },
  "mac": {
    "target": "dmg",
    "icon": "build/icon.icns"
  }
}
